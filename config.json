{
    "$schema": "config-schema.json",
    "model": {
        "name": "qwen/qwen3.5-9b"
    },
    "file_tools": {
        "folders": [
            { "alias": "ai_files", "path": "E:\\ai\\sandbox", "access": "rw" },
            { "alias": "user_share", "path": "C:\\publicshare", "access": "ro" }
        ],
        "trash_path": "E:\\ai\\trash"
    },
    "memory": {
        "storage_path": "memory.json"
    },
    "agent": {
        "users_name": "Tom",
        "agents_name": "Alfred",
        "extra_info": [],
        "prompt_limit": 3500
    },
    "speech_to_text": {
        "enabled": true,
        "trigger_key": "alt_gr"
    },
    "email": {
        "user_inbox": {
            "imap_host": "imap.example.com",
            "imap_port": 993,
            "username": "user@example.com",
            "password": "your-app-password"
        },
        "agent_inbox": {
            "imap_host": "imap.example.com",
            "imap_port": 993,
            "smtp_host": "smtp.example.com",
            "smtp_port": 587,
            "username": "agent@example.com",
            "password": "your-app-password",
            "send_whitelist": ["trusted@example.com"]
        },
        "storage_path": "email_state.json",
        "max_body_chars": 4000,
        "poll_interval_seconds": 300
    },
    "allowed_apps": [
        {
            "name": "Steam",
            "description": "The Steam game launcher",
            "path": "C:\\Program Files (x86)\\Steam\\steam.exe"
        },
        {
            "name": "Pico-8",
            "description": "The Pico-8 fantasy console",
            "path": "C:\\Program Files (x86)\\PICO-8\\pico8.exe"
        },
        {
            "name": "Email",
            "path": "C:\\Program Files\\Mozilla Thunderbird\\thunderbird.exe"
        },
        {
            "name": "Gimp",
            "description": "The gimp image editor",
            "path": "C:\\Program Files\\GIMP 2\\bin\\gimp-2.10.exe"
        },
        {
            "name": "Blender3D",
            "description": "The Blender 3D modelling tool",
            "path": "C:\\Program Files\\Blender Foundation\\Blender 3.3\\blender-launcher.exe"
        }
    ]
}
