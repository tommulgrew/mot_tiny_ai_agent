{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Tiny agent config",
    "type": "object",
    "additionalProperties": false,

    "properties": {
        "$schema": {
            "type": "string"
        },
        "model": {
            "type": "object",
            "additionalProperties": false,
            "description": "LLM chat completion service configuration",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the LLM model to use"
                },
                "url": {
                    "type": "string",
                    "description": "URL to chat completions service. Currently supports OpenAI protocol (e.g. LM Studio)",
                    "default": "http://localhost:1234/v1"
                },
                "api_key": {
                    "type": "string",
                    "description": "API key, if required",
                    "default": "[not used]"
                },
                "prompt_token_limit": {
                    "type": "number",
                    "description": "Prompt size limit in tokens. History messages will be removed once limit is reached."
                }
            },
            "required":["name"]
        },
        "file_tools": {
            "type": "object",
            "additionalProperties": false,
            "description": "File and folder AI tool calls",
            "required": [ "folders", "trash_path" ],
            "properties": {
                "folders": {
                    "type": "array",
                    "description": "List of folders the agent can access, exposed to the LLM as aliases.",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["alias", "path", "access"],
                        "properties": {
                            "alias": {
                                "type": "string",
                                "description": "The name the LLM uses to refer to this folder (e.g. 'notes')"
                            },
                            "path": {
                                "type": "string",
                                "description": "Absolute path to the folder on disk."
                            },
                            "access": {
                                "type": "string",
                                "enum": ["ro", "rw"],
                                "description": "'ro' for read-only, 'rw' for read/write."
                            }                            
                        }
                    }
                },
                "trash_path": {
                    "type": "string",
                    "description": "Absolute path to the 'trash' folder, where files are moved when the LLM 'deletes' them."
                }
            }
        },
        "memory": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "storage_path": {
                    "type": "string",
                    "description": "Path and filename to memory JSON file"
                }
            }
        },
        "agent": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "users_name": {
                    "type": "string",
                    "description": "The user's name"
                },
                "agents_name": {
                    "type": "string",
                    "description": "The AI agent's name"
                },
                "extra_info": {
                    "type": "array",
                    "description": "Any extra information for the agent. This is included in the system prompt.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "speech_to_text": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "enabled" ],
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "model_size": {
                    "enum": ["tiny", "base", "small", "medium", "large"],
                    "description": "fast-whisper model size. Larger models are more accurate but slower. 'small' is recommended for CPU use.",
                    "default": "small"
                },
                "trigger_key": {
                    "type": "string",
                    "default": "ctrl_r",
                    "description": "pynput key name to use as the push-to-talk trigger (e.g. 'ctrl_r' for right Ctrl). Hold to record, release to transcribe."
                },
                "language": {
                    "type": "string",
                    "description": "BCP-47 language code for transcription (e.g. 'en'). Omit to enable auto-detection."
                },
                "sample_rate": {
                    "type": "number",
                    "default": 16000,
                    "description": "Sampling rate (Hz)"
                }
            }
        },
        "todo": {
            "type": "object",
            "additionalProperties": false,
            "description": "To-do list tool configuration.",
            "properties": {
                "storage_path": {
                    "type": "string",
                    "default": "tasks.json",
                    "description": "Path to JSON file storing active tasks."
                },
                "completed_log_path": {
                    "type": "string",
                    "default": "tasks_completed.jsonl",
                    "description": "Path to append-only JSONL file where completed tasks are logged."
                },
                "agent_list_limit": {
                    "type": "number",
                    "default": 20,
                    "description": "Maximum number of active tasks in the agent list."
                },
                "user_list_limit": {
                    "type": "number",
                    "default": 50,
                    "description": "Maximum number of active tasks in the user list."
                }
            }
        },
        "email": {
            "type": "object",
            "additionalProperties": false,
            "description": "Email tool configuration. Supports a read-only user inbox and a read/write agent inbox.",
            "properties": {
                "user_inbox": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "Read-only IMAP inbox for the user's personal email.",
                    "required": ["imap_host", "username"],
                    "properties": {
                        "imap_host": { "type": "string", "description": "IMAP server hostname" },
                        "imap_port": { "type": "number", "default": 993, "description": "IMAP port (SSL)" },
                        "username":  { "type": "string", "description": "IMAP login username (usually the email address)" },
                        "password":  { "type": "string", "description": "IMAP password or app-specific password. If omitted, the password is looked up from the OS keyring (Windows Credential Manager on Windows), and the user is prompted to enter it on first run." }
                    }
                },
                "agent_inbox": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "IMAP/SMTP inbox for the agent. Can send email to addresses in the send_whitelist.",
                    "required": ["imap_host", "username", "smtp_host"],
                    "properties": {
                        "imap_host":      { "type": "string", "description": "IMAP server hostname" },
                        "imap_port":      { "type": "number", "default": 993, "description": "IMAP port (SSL)" },
                        "username":       { "type": "string", "description": "IMAP/SMTP login username (usually the email address)" },
                        "password":       { "type": "string", "description": "IMAP/SMTP password or app-specific password. If omitted, the password is looked up from the OS keyring (Windows Credential Manager on Windows), and the user is prompted to enter it on first run." },
                        "smtp_host":      { "type": "string", "description": "SMTP server hostname" },
                        "smtp_port":      { "type": "number", "default": 587, "description": "SMTP port (STARTTLS)" },
                        "send_whitelist": {
                            "type": "array",
                            "description": "Email addresses the agent is permitted to send to.",
                            "items": { "type": "string" }
                        }
                    }
                },
                "storage_path": {
                    "type": "string",
                    "default": "email_state.json",
                    "description": "Path to JSON file used to track read emails and polling state."
                },
                "max_body_chars": {
                    "type": "number",
                    "default": 4000,
                    "description": "Maximum characters returned per read_email call. Larger emails are truncated with a continuation hint."
                },
                "poll_interval_seconds": {
                    "type": "number",
                    "default": 300,
                    "description": "How often (in seconds) to poll inboxes for new emails."
                }
            }
        },
        "allowed_apps": {
            "type": "array",
            "description": "White list of apps the agent is allowed to launch.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [ "name", "path" ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the application. This is what the agent will use to launch it."                        
                    },
                    "path": {
                        "type": "string",
                        "description": "The full path and filename"
                    },
                    "description": {
                        "type": "string",
                        "description": "Short description of the application, displayed to the agent when apps are listed."
                    },
                    "start_in_folder": {
                        "type": "string",
                        "description": "The full path to the folder to start the application in. If ommitted will be inferred from the 'path'."
                    }
                }
            }
        }
    },
    "required": ["model"]
}